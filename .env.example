# MongoDB Connection
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/ucademy

# Clerk Authentication - Public Key (Safe to expose in client)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Clerk Authentication - Secret Key (Server-side only)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Webhook Secret for Clerk Events (used in /api/webhook)
WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Optional: Next.js Environment
# NODE_ENV=development
